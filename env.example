# Copy to .env and fill in real values.

PATIENT_ID=patient_001
BACKEND_URL=http://localhost:5000/api/emotions
SEND_INTERVAL=5
LIVE_STREAM_PORT=5001
PATIENT_PHOTO_DIR=patient_photos
DISTRESS_THRESHOLD=45
DISTRESS_HOLD_SECONDS=5
DISTRESS_COOLDOWN=60

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio WhatsApp Sandbox sender number (same for everyone unless you upgrade).
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Caretaker phone in E.164. Must first join the sandbox by sending
# "join <two-word-code>" from WhatsApp to +14155238886 (code shown in Twilio console).
CARETAKER_PHONE=+919876543210
